{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pull Request Comment Decision Item",
  "type": "object",
  "required": [
    "item_id",
    "comment_id",
    "source_type",
    "summary",
    "classification",
    "recommended_action",
    "decision_status"
  ],
  "properties": {
    "item_id": {
      "type": "string",
      "description": "Identificador estavel do item dentro da rodada de triagem."
    },
    "comment_id": {
      "type": [
        "integer",
        "string",
        "null"
      ]
    },
    "source_type": {
      "type": "string",
      "enum": [
        "issue_comment",
        "review_comment"
      ]
    },
    "author": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "url": {
      "type": [
        "string",
        "null"
      ]
    },
    "path": {
      "type": [
        "string",
        "null"
      ]
    },
    "line": {
      "type": [
        "integer",
        "null"
      ]
    },
    "summary": {
      "type": "string"
    },
    "raw_excerpt": {
      "type": [
        "string",
        "null"
      ]
    },
    "classification": {
      "type": "string",
      "enum": [
        "bug",
        "melhoria",
        "sugestao",
        "duvida",
        "nit",
        "documentacao",
        "teste",
        "risco",
        "outro"
      ]
    },
    "recommended_action": {
      "type": "string"
    },
    "decision_status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected",
        "skipped",
        "published"
      ]
    }
  },
  "additionalProperties": true
}
